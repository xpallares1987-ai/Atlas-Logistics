{
  "name": "Atlas Logistics ERP — Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/postgresql:1": {
      "version": "16",
      "userName": "postgres",
      "userPassword": "changeme",
      "databaseName": "atlas_dev"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Variables de entorno del contenedor — apuntan a la BD local del devcontainer
  "containerEnv": {
    "NODE_ENV": "development",
    "PORT": "3001",
    "DATABASE_HOST": "localhost",
    "DATABASE_PORT": "5432",
    "DATABASE_USER": "postgres",
    "DATABASE_PASSWORD": "changeme",
    "DATABASE_NAME": "atlas_dev",
    "DATABASE_URL": "postgresql://postgres:changeme@localhost:5432/atlas_dev",
    // Las siguientes variables necesitan configurarse manualmente en tu .env.local
    // CAMUNDA_CLIENT_ID, CAMUNDA_CLIENT_SECRET, CAMUNDA_CLUSTER_ID, GEMINI_API_KEY
    "VITE_API_URL": "http://localhost:3001/api"
  },

  // Puertos accesibles desde el host
  "forwardPorts": [3001, 5173, 5432],
  "portsAttributes": {
    "3001": { "label": "Backend API", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (Vite)", "onAutoForward": "openBrowser" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },

  // Script de inicialización de la BD
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer,target=/docker-entrypoint-initdb.d,type=bind,consistency=cached"
  ],

  // Tras crear el contenedor: instalar dependencias, aplicar schema y hacer seed
  "postCreateCommand": "npm install -g pnpm@10 && pnpm install --no-frozen-lockfile --ignore-scripts && pnpm run db:push && pnpm run db:seed",

  "customizations": {
    "vscode": {
      "extensions": [
        // TypeScript / JS
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // Base de datos
        "cweijan.vscode-postgresql-client2",
        // Docker
        "ms-azuretools.vscode-docker",
        // REST / API
        "humao.rest-client",
        // Git
        "eamodio.gitlens",
        // Tailwind CSS
        "bradlc.vscode-tailwindcss",
        // Drizzle ORM
        "rphlmr.vscode-drizzle-orm",
        // Remote / Dev Containers
        "ms-vscode-remote.vscode-remote-extensionpack",
        // Live Share (colaboración)
        "ms-vsliveshare.vsliveshare",
        // GitHub Actions
        "github.vscode-github-actions",
        // Turbo (monorepo)
        "vercel.turbo-vsc"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
        "typescript.preferences.importModuleSpecifier": "relative",
        "typescript.updateImportsOnFileMove.enabled": "always",
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  }
}
