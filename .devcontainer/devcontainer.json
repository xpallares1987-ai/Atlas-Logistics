{
  "name": "Atlas Logistics",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "pnpmVersion": "latest"
    }
  },
  "onCreateCommand": "sudo service postgresql start && (sudo -u postgres psql -tAc \"SELECT 1 FROM pg_database WHERE datname = 'atlas_scm'\" | grep -qx 1 || sudo -u postgres createdb atlas_scm)",
  "postStartCommand": "sudo service postgresql start",
  "forwardPorts": [3000, 5432],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "postCreateCommand": "pnpm install",
  "remoteUser": "node"
}
