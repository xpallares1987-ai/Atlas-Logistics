{
  "name": "Node.js & TypeScript w/ PostgreSQL",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/postgresql:1": {
      "version": "latest",
      "userName": "postgres",
      "userPassword": "postgres",
      "databaseName": "appdb"
    }
  },

  // =====================================================================================
  // NOTA: Estas variables de entorno son EXCLUSIVAMENTE para la base de datos
  //       PostgreSQL que se ejecuta DENTRO de este Dev Container para desarrollo local.
  //       La aplicación en producción utiliza Firebase Data Connect para conectarse
  //       a una instancia de Google Cloud SQL.
  // =====================================================================================
  "containerEnv": {
    "DATABASE_HOST": "localhost",
    "DATABASE_PORT": "5432",
    "DATABASE_USER": "postgres",
    "DATABASE_PASSWORD": "postgres",
    "DATABASE_NAME": "appdb",
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/appdb",
    "NODE_ENV": "development",
    "PORT": "3000"
  },

  // Forward the default PostgreSQL port so you can connect from your local machine.
  "forwardPorts": [ 5432 ],

  // Mounts a folder of SQL scripts into the container to initialize the database.
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/init-scripts,target=/docker-entrypoint-initdb.d,type=bind,consistency=cached"
  ],

  // Run 'npm install' automatically after the container is created.
  "postCreateCommand": "npm install",

  // Configure editor-specific settings.
  "customizations": {
    // Configure properties specific to VS Code.
    "vscode": {
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "cweijan.vscode-postgresql-client2",
        "ms-python.python",
        "ms-python.vscode-pylance", // Included for Python development
        "ms-toolsai.jupyter", // Included for Jupyter notebooks
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-vscode.vscode-typescript-next",
        "ms-vsliveshare.vsliveshare",
        "ms-vsliveshare.vsliveshare-audio",
        "ms-vsliveshare.vsliveshare-pack"
      ],
      // Use 'settings' to set *default* container specific settings.json values on container create.
      "settings": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "eslint.validate": [
          "javascript",
          "typescript"
        ]
      }
    }
  }
}
