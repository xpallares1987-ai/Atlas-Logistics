{
  "name": "atlas-logistics",
  "version": "1.0.0",
  "description": "SCM Freight Forwarding MVP",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:frontend": "pnpm --filter @atlas/frontend dev",
    "dev:backend": "node dist/server.js",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:frontend": "pnpm --filter @atlas/frontend build",
    "build:backend": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node dist/db/migrate.js",
    "db:seed": "node dist/db/seed.js",
    "test": "pnpm --filter @torre/shared test",
    "type-check": "pnpm --filter @atlas/frontend type-check && tsc -p tsconfig.server.json --noEmit",
    "eslint": "eslint .",
    "lint": "pnpm run type-check && pnpm run eslint",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "argon2": "^0.44.0",
    "bpmn-js": "^18.17.1",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.3.2",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@camunda8/sdk": "^8.8.11",
    "@grpc/grpc-js": "^1.9.16",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@types/node": "26",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.5",
    "fast-uri": "^4.0.0",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.8.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.24.0",
    "uuid": "^14.0.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "concurrently": "^10.0.3"
  }
}