{
  "name": "atlas-logistics",
  "version": "1.0.0",
  "description": "SCM Freight Forwarding MVP",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "dev:frontend": "pnpm --filter @atlas/frontend dev",
    "dev:backend": "pnpm exec tsx watch src/server.ts",
    "build": "pnpm run build:backend && pnpm run build:frontend",
    "build:frontend": "pnpm --filter @atlas/frontend build",
    "build:backend": "tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "node dist/db/migrate.js",
    "db:seed": "node dist/db/seed.js",
    "db:clean-logs": "node dist/scripts/db-log-cleanup.js",
    "test": "pnpm --filter @torre/shared test",
    "type-check": "pnpm --filter @atlas/frontend type-check && tsc -p tsconfig.server.json --noEmit",
    "eslint": "eslint .",
    "lint": "pnpm run type-check && pnpm run eslint",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@fastify/websocket": "^11.2.0",
    "argon2": "^0.44.0",
    "d3-color": "^3.1.0",
    "fastify-type-provider-zod": "^1.2.0",
    "ioredis": "^5.11.1",
    "pdfkit": "^0.19.1",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@camunda8/sdk": "^8.8.11",
    "@grpc/grpc-js": "^1.14.4",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@types/node": "^20.19.43",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "fast-uri": "^4.1.0",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.9.0",
    "postcss": "^8.5.16",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "uuid": "^14.0.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "d3-color": "^3.1.0",
      "esbuild": "^0.25.0",
      "postcss": "^8.5.14"
    }
  }
}