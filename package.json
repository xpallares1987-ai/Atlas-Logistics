{
  "name": "atlas-logistics",
  "version": "1.0.0",
  "description": "SCM Freight Forwarding MVP",
  "type": "module",
  "scripts": {
    "dev": "vite src/frontend",
    "build": "pnpm run build:frontend && pnpm run build:backend",
    "build:frontend": "vite build src/frontend",
    "build:backend": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:migrate": "node dist/db/migrate.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "bpmn-js": "^17.0.2",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.3.2",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@camunda8/sdk": "^8.8.11",
    "@grpc/grpc-js": "^1.9.16",
    "@types/node": "20",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "fast-uri": "^4.0.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "typescript": "^5.4.5",
    "uuid": "^14.0.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.1.8"
  }
}