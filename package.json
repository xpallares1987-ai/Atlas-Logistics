  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "pnpm run type-check && pnpm run eslint",
    "test": "pnpm --filter @atlas/shared test",
    "type-check": "pnpm --filter @atlas/frontend type-check",
    "eslint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky",
    "db:generate": "npx -y firebase-tools@latest dataconnect:sdk:generate",
    "db:push": "npx -y firebase-tools@latest dataconnect:sql:migrate",
    "db:reset": "sh .devcontainer/reset-db.sh",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset-and-seed": "sh .devcontainer/reset-db.sh && tsx src/db/seed.ts",
    "start:backend": "tsx --env-file=.env.local src/server.ts | pino-pretty",
    "start:worker": "tsx --env-file=.env.local src/worker-node.ts | pino-pretty",
    "test:e2e": "playwright test"
  },
