# ==============================================================================
# ATLAS-LOGISTICS - LOCAL ENVIRONMENT VARIABLES
# ==============================================================================
# IMPORTANTE: Este archivo .env NUNCA debe subirse a un repositorio público.
# Los valores reales de desarrollo se guardan en tu equipo.

# 1. Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT="atlas-logistics-dev"
GOOGLE_APPLICATION_CREDENTIALS="C:\Users\xpall\keys\atlas-logistics-gcp-key.json"
FIREBASE_TOKEN=""

# 2. Inteligencia Artificial (Gemini)
# Tu clave API personal de Google AI Studio / Vertex AI
GEMINI_API_KEY="AIzaSy..."
GOOGLE_API_KEY="AIzaSy..."

# 3. Monorepo (Turborepo) y GitHub
# Requeridos para GitHub Actions (Pull requests, Code scanning, Cache)
GH_PAT=""
TURBO_TOKEN=""
TURBO_TEAM="tu-equipo-vercel"

# 4. Base de Datos (Cloud SQL / PostgreSQL local / Data Connect)
# Se utiliza en migraciones locales o Data Connect offline mode
DATABASE_URL="postgresql://postgres:password@localhost:5432/atlas_db"

# 5. Puertos de Frontend / Vite (Opcional)
VITE_PORT="5173"
PORT="3000"
