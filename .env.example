# ==============================================================================
# ATLAS-LOGISTICS - LOCAL ENVIRONMENT VARIABLES
# ==============================================================================
# IMPORTANTE: Este archivo .env NUNCA debe subirse a un repositorio público.
# Los valores reales de desarrollo se guardan en tu equipo.
# NOTA CRÍTICA DE SEGURIDAD: Los secretos (contraseñas, tokens, API keys)
# deben almacenarse en un gestor de secretos (Docker Secrets, Vault, etc),
# NO en archivos .env. Usa Docker Secrets en producción.

# 1. Base de Datos
# (PostgreSQL gestionado nativamente por Firebase Data Connect. No se requieren variables locales).

# 2. Google Cloud / Firebase (Development Only)
GOOGLE_CLOUD_PROJECT=atlas-logistics-dev
GOOGLE_APPLICATION_CREDENTIALS=/path/to/tower-sa-key.json
FIREBASE_TOKEN=

# 3. Inteligencia Artificial (Gemini)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# 4. Monorepo (Turborepo) y GitHub
# Requeridos para GitHub Actions (Pull requests, Code scanning, Cache)
GH_PAT=
TURBO_TOKEN=
TURBO_TEAM=

# 6. Puertos y Frontend
VITE_PORT=5173
PORT=3000

# ==============================================================================
# SECURITY BEST PRACTICES:
# ==============================================================================
# - NEVER commit .env to git. Use .env.example as a template.
# - ALWAYS use a secrets manager for production (Docker Secrets, HashiCorp Vault, AWS Secrets Manager, etc).
# - ALWAYS rotate credentials regularly.
# - NEVER share or hardcode secrets in Dockerfiles or compose files.
# - For Docker Swarm: use `docker secret create` and reference with `secrets:` key.
# - For Kubernetes: use native Secrets objects or external secret operators.
# ==============================================================================
