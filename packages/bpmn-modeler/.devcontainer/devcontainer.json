{
  "name": "BPMN Modeler",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "pnpmVersion": "latest"
    }
  },
  "forwardPorts": [5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bpmn-io.bpmn-lint",
        "vscjava.vscode-bpmn-io"
      ]
    }
  },
  "postCreateCommand": "pnpm install",
  "remoteUser": "node"
}
