{
    "gemini-cli.debug.logging.enabled": true,
    "gemini-cli.executablePath": "C:\\Users\\xpall\\AppData\\Local\\agy\\bin\\agy.exe",
    "gemini-cli.port": 3000,

    "docker.languageserver.formatter.ignoreMultilineInstructions": true,
    "containers.truncateLongRegistryPaths": true,
    "containers.contexts.showInStatusBar": true,
    "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",

    "npm-intellisense.packageSubfoldersIntellisense": true,
    "npm-intellisense.scanDevDependencies": true,
    "npm-intellisense.showBuildInLibs": true,
    "npm.packageManager": "pnpm",

    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "tailwindCSS.experimental.classRegex": [
        [ "cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]" ]
    ],
    "firebase.dataConnect.alwaysAllowMutationsInProduction": true,
    "firebase.dataConnect.skipToAppFolderSelect": true,
    "firebase.emulators.exportOnExit": true,
    "firebase.debug": true,
    "firebase.emulators.exportPath": "./.firebase-data",
    "firebase.emulators.importPath": "./.firebase-data",
    "firebase.firebasePath": "./node_modules/firebase",
    "editor.wordWrap": "on",
    "editor.tabSize": 2,
    "editor.mouseWheelZoom": true,
    "editor.formatOnPaste": true,
    "editor.autoIndentOnPaste": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.codeActions.triggerOnFocusChange": true,
    "editor.columnSelection": true,
    "editor.definitionLinkOpensInPeek": true,
    "editor.experimental.asyncTokenizationLogging": true,
    "editor.foldingImportsByDefault": true,
    "editor.hideCursorInOverviewRuler": true,
    "editor.inlayHints.padding": true,
    "editor.linkedEditing": true,
    "editor.renderLineHighlightOnlyWhenFocus": true,
    "editor.renderRichScreenReaderContent": true,
    "editor.scrollbar.ignoreHorizontalScrollbarInContentHeight": true,
    "editor.scrollbar.scrollByPage": true,
    "editor.scrollOnMiddleClick": true,
    "editor.suggest.localityBonus": true,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.suggest.shareSuggestSelections": true,
    "editor.suggest.showStatusBar": true
}
