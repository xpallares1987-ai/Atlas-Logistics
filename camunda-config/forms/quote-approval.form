{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.8.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.0.0"
  },
  "schemaVersion": 16,
  "id": "quote-approval",
  "components": [
    {
      "type": "text",
      "text": "# Quote Approval\nReview the quote details below and approve or reject.",
      "id": "header"
    },
    {
      "type": "separator",
      "id": "sep1"
    },
    {
      "type": "textfield",
      "label": "Quote Number",
      "key": "quoteNumber",
      "id": "quoteNumber",
      "readonly": true,
      "description": "Auto-generated reference"
    },
    {
      "type": "textfield",
      "label": "Customer",
      "key": "customer",
      "id": "customer",
      "readonly": true
    },
    {
      "type": "columns",
      "id": "routeColumns",
      "columns": [
        {
          "components": [
            {
              "type": "textfield",
              "label": "Origin",
              "key": "origin",
              "id": "origin",
              "readonly": true
            }
          ]
        },
        {
          "components": [
            {
              "type": "textfield",
              "label": "Destination",
              "key": "destination",
              "id": "destination",
              "readonly": true
            }
          ]
        }
      ]
    },
    {
      "type": "textfield",
      "label": "Equipment",
      "key": "equipment",
      "id": "equipment",
      "readonly": true
    },
    {
      "type": "separator",
      "id": "sep2"
    },
    {
      "type": "text",
      "text": "## Financial Details",
      "id": "finHeader"
    },
    {
      "type": "columns",
      "id": "finColumns",
      "columns": [
        {
          "components": [
            {
              "type": "number",
              "label": "Buy Rate (USD)",
              "key": "buyRateTotal",
              "id": "buyRate",
              "readonly": true,
              "decimalDigits": 2
            }
          ]
        },
        {
          "components": [
            {
              "type": "number",
              "label": "Sell Rate (USD)",
              "key": "sellRateTotal",
              "id": "sellRate",
              "readonly": true,
              "decimalDigits": 2
            }
          ]
        },
        {
          "components": [
            {
              "type": "number",
              "label": "Margin (%)",
              "key": "sellMargin",
              "id": "margin",
              "readonly": true,
              "decimalDigits": 1
            }
          ]
        }
      ]
    },
    {
      "type": "textfield",
      "label": "Selected Carrier",
      "key": "selectedCarrier",
      "id": "carrier",
      "readonly": true
    },
    {
      "type": "number",
      "label": "Transit Time (days)",
      "key": "transitTime",
      "id": "transitTime",
      "readonly": true
    },
    {
      "type": "separator",
      "id": "sep3"
    },
    {
      "type": "select",
      "label": "Decision",
      "key": "quoteApprovalDecision",
      "id": "decision",
      "validate": {
        "required": true
      },
      "values": [
        { "label": "✅ Approve", "value": "APPROVED" },
        { "label": "🔄 Return for Revision", "value": "REVISION_NEEDED" },
        { "label": "❌ Reject", "value": "REJECTED" }
      ]
    },
    {
      "type": "textarea",
      "label": "Comments / Reason",
      "key": "approvalComments",
      "id": "comments",
      "description": "Required if rejecting or requesting revision",
      "validate": {
        "minLength": 0,
        "maxLength": 1000
      }
    }
  ],
  "type": "default"
}
