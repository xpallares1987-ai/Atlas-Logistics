        },
        {
          "label": "Rejected",
          "value": "REJECTED"
        }
      ],
      "validate": {
        "required": true
      }
    },
    {
      "label": "Receiver Name",
      "type": "textfield",
      "id": "Field_0m9n2b4",
      "key": "receiverName",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Delivery Remarks / Exceptions",
