        { "label": "I - High Danger", "value": "I" },
        { "label": "II - Medium Danger", "value": "II" },
        { "label": "III - Low Danger", "value": "III" }
      ]
    },
    {
      "label": "DGD Document Uploaded?",
      "type": "checkbox",
      "id": "Field_2c9x5v6",
