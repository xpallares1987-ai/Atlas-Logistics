{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.10.0",
  "exporter": { "name": "Camunda Modeler", "version": "5.0.0" },
  "schemaVersion": 16,
  "id": "invoice-review",
  "components": [
    {
      "type": "text",
      "text": "# 📋 Invoice Discrepancy Review\nVendor invoice amounts do not match expected costs. Please review and decide.",
      "id": "header"
    },
    { "type": "separator", "id": "sep1" },
    {
      "type": "textfield",
      "label": "Shipment Reference",
      "key": "referenceNumber",
      "id": "refNumber",
      "readonly": true
    },
    {
      "type": "textfield",
      "label": "Vendor / Carrier",
      "key": "vendorName",
      "id": "vendor",
      "readonly": true
    },
    {
      "type": "columns",
      "id": "amounts",
      "columns": [
        { "components": [{ "type": "number", "label": "Expected Amount (USD)", "key": "expectedAmount", "id": "expected", "readonly": true, "decimalDigits": 2 }] },
        { "components": [{ "type": "number", "label": "Invoiced Amount (USD)", "key": "actualAmount", "id": "actual", "readonly": true, "decimalDigits": 2 }] },
        { "components": [{ "type": "number", "label": "Variance (USD)", "key": "variance", "id": "variance", "readonly": true, "decimalDigits": 2 }] }
      ]
    },
    {
      "type": "number",
      "label": "Variance (%)",
      "key": "variancePercent",
      "id": "variancePct",
      "readonly": true,
      "decimalDigits": 1
    },
    { "type": "separator", "id": "sep2" },
    {
      "type": "select",
      "label": "Decision",
      "key": "invoiceReviewDecision",
      "id": "decision",
      "validate": { "required": true },
      "values": [
        { "label": "✅ Accept — difference is justified", "value": "ACCEPT" },
        { "label": "🔄 Dispute — request credit note", "value": "DISPUTE" },
        { "label": "⚖️ Split — partial acceptance", "value": "SPLIT" },
        { "label": "❌ Reject invoice", "value": "REJECT" }
      ]
    },
    {
      "type": "number",
      "label": "Accepted Amount (if split)",
      "key": "acceptedAmount",
      "id": "acceptedAmount",
      "decimalDigits": 2
    },
    {
      "type": "textarea",
      "label": "Reviewer Notes",
      "key": "reviewerNotes",
      "id": "notes",
      "validate": { "required": true, "minLength": 10 },
      "description": "Explain the rationale for your decision"
    }
  ],
  "type": "default"
}
