        <di:waypoint x="470" y="540" />
        <di:waypoint x="570" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToContracts" bpmnElement="Flow_ToContracts">
        <di:waypoint x="470" y="355" />
        <di:waypoint x="470" y="750" />
        <di:waypoint x="570" y="750" />
      </bpmndi:BPMNEdge>

      <!-- Branches → Join (normal) -->
      <bpmndi:BPMNEdge id="Edge_MaerskToJoin" bpmnElement="Flow_MaerskToJoin">
        <di:waypoint x="670" y="120" />
        <di:waypoint x="810" y="120" />
        <di:waypoint x="810" y="305" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MSCToJoin" bpmnElement="Flow_MSCToJoin">
        <di:waypoint x="670" y="330" />
        <di:waypoint x="785" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_HapagToJoin" bpmnElement="Flow_HapagToJoin">
        <di:waypoint x="670" y="540" />
        <di:waypoint x="810" y="540" />
        <di:waypoint x="810" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ContractsToJoin" bpmnElement="Flow_ContractsToJoin">
        <di:waypoint x="670" y="750" />
        <di:waypoint x="810" y="750" />
        <di:waypoint x="810" y="355" />
      </bpmndi:BPMNEdge>

      <!-- Branches → Join (timer) -->
      <bpmndi:BPMNEdge id="Edge_MaerskTimerToJoin" bpmnElement="Flow_MaerskTimerToJoin">
        <di:waypoint x="660" y="178" />
        <di:waypoint x="660" y="190" />
        <di:waypoint x="750" y="190" />
        <di:waypoint x="750" y="315" />
        <di:waypoint x="785" y="315" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MSCTimerToJoin" bpmnElement="Flow_MSCTimerToJoin">
        <di:waypoint x="660" y="388" />
        <di:waypoint x="660" y="400" />
        <di:waypoint x="750" y="400" />
        <di:waypoint x="750" y="340" />
        <di:waypoint x="785" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_HapagTimerToJoin" bpmnElement="Flow_HapagTimerToJoin">
        <di:waypoint x="660" y="598" />
        <di:waypoint x="660" y="610" />
        <di:waypoint x="750" y="610" />
        <di:waypoint x="750" y="345" />
        <di:waypoint x="785" y="345" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ContractsTimerToJoin" bpmnElement="Flow_ContractsTimerToJoin">
        <di:waypoint x="660" y="808" />
        <di:waypoint x="660" y="820" />
        <di:waypoint x="750" y="820" />
        <di:waypoint x="750" y="350" />
        <di:waypoint x="785" y="350" />
      </bpmndi:BPMNEdge>

      <!-- Error boundary flows -->
      <bpmndi:BPMNEdge id="Edge_MaerskError" bpmnElement="Flow_MaerskError">
        <di:waypoint x="620" y="178" />
        <di:waypoint x="620" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MaerskErrorEnd" bpmnElement="Flow_MaerskErrorEnd">
        <di:waypoint x="670" y="240" />
        <di:waypoint x="700" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MSCError" bpmnElement="Flow_MSCError">
        <di:waypoint x="620" y="388" />
        <di:waypoint x="620" y="410" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_MSCErrorEnd" bpmnElement="Flow_MSCErrorEnd">
