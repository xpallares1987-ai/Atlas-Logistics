        <di:waypoint x="700" y="450" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_HapagError" bpmnElement="Flow_HapagError">
        <di:waypoint x="620" y="598" />
        <di:waypoint x="620" y="620" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_HapagErrorEnd" bpmnElement="Flow_HapagErrorEnd">
        <di:waypoint x="670" y="660" />
        <di:waypoint x="700" y="660" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ContractsError" bpmnElement="Flow_ContractsError">
        <di:waypoint x="620" y="808" />
        <di:waypoint x="620" y="830" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ContractsErrorEnd" bpmnElement="Flow_ContractsErrorEnd">
        <di:waypoint x="670" y="870" />
        <di:waypoint x="700" y="870" />
      </bpmndi:BPMNEdge>

      <!-- Post-join spine -->
      <bpmndi:BPMNEdge id="Edge_ToPricingRules" bpmnElement="Flow_ToPricingRules">
        <di:waypoint x="835" y="330" />
        <di:waypoint x="900" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ToRank" bpmnElement="Flow_ToRank">
