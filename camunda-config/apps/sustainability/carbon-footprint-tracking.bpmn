<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_Sus" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.25.0">
  <bpmn:process id="carbon-footprint-tracking" name="Carbon Footprint Tracking" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Shipment Completed">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="Task_CalculateEmissions" name="Calculate CO2 Emissions">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="emissions-calculator" resultVariable="emissionsResult" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_RequestReport" name="Request ESG Report">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="camunda-forms:esg-report-request" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_GenerateReport" name="Generate Certificate">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.esg.generate-cert" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1" name="ESG Process Finished">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CalculateEmissions" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CalculateEmissions" targetRef="Task_RequestReport" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_RequestReport" targetRef="Task_GenerateReport" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_GenerateReport" targetRef="EndEvent_1" />
  </bpmn:process>
</bpmn:definitions>
