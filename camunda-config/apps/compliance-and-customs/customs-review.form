{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.10.0",
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.0.0"
  },
  "schemaVersion": 16,
  "id": "customs-review",
  "components": [
    {
      "type": "text",
      "text": "# ⚠️ Customs Restriction Review\nThe following shipment has triggered a customs restriction alert. Please review and decide.",
      "id": "header"
    },
    {
      "type": "separator",
      "id": "sep1"
    },
    {
      "type": "text",
      "text": "## Shipment Details",
      "id": "shipmentHeader"
    },
    {
      "type": "textfield",
      "label": "Shipment Reference",
      "key": "referenceNumber",
      "id": "refNumber",
      "readonly": true
    },
    {
      "type": "columns",
      "id": "routeColumns",
      "columns": [
        {
          "components": [
            {
              "type": "textfield",
              "label": "Origin",
              "key": "origin",
              "id": "origin",
              "readonly": true
            }
          ]
        },
        {
          "components": [
            {
              "type": "textfield",
              "label": "Origin Country",
              "key": "originCountry",
              "id": "originCountry",
              "readonly": true
            }
          ]
        },
        {
          "components": [
            {
              "type": "textfield",
              "label": "Destination",
              "key": "destination",
              "id": "destination",
              "readonly": true
            }
          ]
        },
        {
          "components": [
            {
              "type": "textfield",
              "label": "Dest. Country",
              "key": "destinationCountry",
              "id": "destCountry",
              "readonly": true
            }
          ]
        }
      ]
    },
    {
      "type": "separator",
      "id": "sep2"
    },
    {
      "type": "text",
      "text": "## Restriction Details",
      "id": "restrictionHeader"
    },
    {
      "type": "textfield",
      "label": "HS Code",
      "key": "hsCode",
      "id": "hsCode",
      "readonly": true
    },
    {
      "type": "textfield",
      "label": "Product Description",
      "key": "productDescription",
      "id": "productDesc",
      "readonly": true
    },
    {
      "type": "textfield",
      "label": "Restriction Level",
      "key": "restrictionLevel",
      "id": "restrictionLevel",
      "readonly": true
    },
    {
      "type": "textfield",
      "label": "Required Action",
      "key": "requiredAction",
      "id": "requiredAction",
      "readonly": true
    },
    {
      "type": "textfield",
      "label": "Reason",
      "key": "reason",
      "id": "reason",
      "readonly": true
    },
    {
      "type": "separator",
      "id": "sep3"
    },
    {
      "type": "text",
      "text": "## Decision",
      "id": "decisionHeader"
    },
    {
      "type": "select",
      "label": "Action",
      "key": "customsReviewDecision",
      "id": "decision",
      "validate": {
        "required": true
      },
      "values": [
        { "label": "✅ Proceed with Shipment (License/Permit Available)", "value": "PROCEED" },
        { "label": "🔄 Request Additional Documentation", "value": "REQUEST_DOCS" },
        { "label": "❌ Block Shipment", "value": "BLOCK" }
      ]
    },
    {
      "type": "textfield",
      "label": "License / Permit Number",
      "key": "licenseNumber",
      "id": "licenseNumber",
      "description": "If proceeding, provide the relevant permit number"
    },
    {
      "type": "textarea",
      "label": "Reviewer Notes",
      "key": "reviewerNotes",
      "id": "reviewerNotes",
      "validate": {
        "required": true,
        "minLength": 10,
        "maxLength": 2000
      },
      "description": "Explain the rationale for your decision"
    }
  ],
  "type": "default"
}
