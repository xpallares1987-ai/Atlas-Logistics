<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="Definitions_AirExport"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.0.0">

  <!-- Error Definition -->
  <bpmn:error id="Error_AirlineRejection" name="Airline Rejection" errorCode="AIRLINE_REJECTION" />

  <bpmn:process id="air-export-process" name="Air Export Process" isExecutable="true">

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_1" name="Air Shipment Request">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="camunda-forms:booking-request" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Validate Air Cargo -->
    <bpmn:serviceTask id="Task_ValidateCargo" name="Validate Air Cargo">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.air.validate-cargo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- DG Goods? Gateway -->
    <bpmn:exclusiveGateway id="Gateway_DGGoods" name="DG Goods?">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Prepare DG Declaration -->
    <bpmn:serviceTask id="Task_PrepareDG" name="Prepare DG Declaration">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.air.prepare-dg" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- DG Merge Gateway -->
    <bpmn:exclusiveGateway id="Gateway_DGMerge" name="Merge">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Get Air Rates -->
    <bpmn:serviceTask id="Task_GetRates" name="Get Air Rates">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.rates.fetch-air" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Book with Airline -->
    <bpmn:serviceTask id="Task_BookAirline" name="Book with Airline">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.air.book" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error Boundary Event: Airline Rejection -->
    <bpmn:boundaryEvent id="BoundaryEvent_Rejection" name="Airline Rejection" attachedToRef="Task_BookAirline">
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_Rejection" errorRef="Error_AirlineRejection" />
    </bpmn:boundaryEvent>

    <!-- Error End Event -->
    <bpmn:endEvent id="EndEvent_Rejection" name="Booking Rejected">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Parallel Fork -->
    <bpmn:parallelGateway id="Gateway_ParallelFork" name="Fork Documentation">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Branch A: Generate AWB -->
    <bpmn:serviceTask id="Task_GenerateAWB" name="Generate AWB">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.docs.generate-awb" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Branch B: Customs Export Filing -->
    <bpmn:serviceTask id="Task_CustomsFiling" name="Customs Export Filing">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.customs.export-filing" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Join -->
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Join Documentation">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Cargo Acceptance at Airport -->
    <bpmn:serviceTask id="Task_CargoAcceptance" name="Cargo Acceptance at Airport">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.air.cargo-acceptance" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Flight Departure -->
    <bpmn:serviceTask id="Task_FlightDeparture" name="Flight Departure">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.tracking.flight-departure" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Flight Arrival -->
    <bpmn:serviceTask id="Task_FlightArrival" name="Flight Arrival">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.tracking.flight-arrival" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Generate Invoice -->
    <bpmn:serviceTask id="Task_GenerateInvoice" name="Generate Invoice">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="atlas.invoice.generate" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event -->
    <bpmn:endEvent id="EndEvent_1" name="Air Export Completed">
      <bpmn:incoming>Flow_18</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_ValidateCargo" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ValidateCargo" targetRef="Gateway_DGGoods" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="Gateway_DGGoods" targetRef="Task_PrepareDG">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isDangerousGoods = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_PrepareDG" targetRef="Gateway_DGMerge" />
    <bpmn:sequenceFlow id="Flow_5" name="No" sourceRef="Gateway_DGGoods" targetRef="Gateway_DGMerge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isDangerousGoods = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_DGMerge" targetRef="Task_GetRates" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_GetRates" targetRef="Task_BookAirline" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_BookAirline" targetRef="Gateway_ParallelFork" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="BoundaryEvent_Rejection" targetRef="EndEvent_Rejection" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_ParallelFork" targetRef="Task_GenerateAWB" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gateway_ParallelFork" targetRef="Task_CustomsFiling" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_GenerateAWB" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_CustomsFiling" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Gateway_ParallelJoin" targetRef="Task_CargoAcceptance" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_CargoAcceptance" targetRef="Task_FlightDeparture" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_FlightDeparture" targetRef="Task_FlightArrival" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_FlightArrival" targetRef="Task_GenerateInvoice" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_GenerateInvoice" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="air-export-process">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="162" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="142" y="335" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Validate Air Cargo -->
      <bpmndi:BPMNShape id="Task_ValidateCargo_di" bpmnElement="Task_ValidateCargo">
        <dc:Bounds x="250" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- DG Goods? Gateway -->
      <bpmndi:BPMNShape id="Gateway_DGGoods_di" bpmnElement="Gateway_DGGoods" isMarkerVisible="true">
        <dc:Bounds x="400" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="396" y="261" width="58" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Prepare DG Declaration -->
      <bpmndi:BPMNShape id="Task_PrepareDG_di" bpmnElement="Task_PrepareDG">
        <dc:Bounds x="450" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- DG Merge Gateway -->
      <bpmndi:BPMNShape id="Gateway_DGMerge_di" bpmnElement="Gateway_DGMerge" isMarkerVisible="true">
        <dc:Bounds x="600" y="285" width="50" height="50" />
      </bpmndi:BPMNShape>

      <!-- Get Air Rates -->
      <bpmndi:BPMNShape id="Task_GetRates_di" bpmnElement="Task_GetRates">
        <dc:Bounds x="700" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Book with Airline -->
      <bpmndi:BPMNShape id="Task_BookAirline_di" bpmnElement="Task_BookAirline">
        <dc:Bounds x="850" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Error Boundary Event -->
      <bpmndi:BPMNShape id="BoundaryEvent_Rejection_di" bpmnElement="BoundaryEvent_Rejection">
        <dc:Bounds x="882" y="332" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="858" y="375" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Error End Event -->
      <bpmndi:BPMNShape id="EndEvent_Rejection_di" bpmnElement="EndEvent_Rejection">
        <dc:Bounds x="882" y="432" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="859" y="475" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Parallel Fork -->
      <bpmndi:BPMNShape id="Gateway_ParallelFork_di" bpmnElement="Gateway_ParallelFork">
        <dc:Bounds x="1000" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="978" y="261" width="94" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Branch A: Generate AWB -->
      <bpmndi:BPMNShape id="Task_GenerateAWB_di" bpmnElement="Task_GenerateAWB">
        <dc:Bounds x="1100" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Branch B: Customs Export Filing -->
      <bpmndi:BPMNShape id="Task_CustomsFiling_di" bpmnElement="Task_CustomsFiling">
        <dc:Bounds x="1100" y="370" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Parallel Join -->
      <bpmndi:BPMNShape id="Gateway_ParallelJoin_di" bpmnElement="Gateway_ParallelJoin">
        <dc:Bounds x="1250" y="285" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1225" y="342" width="100" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Cargo Acceptance at Airport -->
      <bpmndi:BPMNShape id="Task_CargoAcceptance_di" bpmnElement="Task_CargoAcceptance">
        <dc:Bounds x="1350" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Flight Departure -->
      <bpmndi:BPMNShape id="Task_FlightDeparture_di" bpmnElement="Task_FlightDeparture">
        <dc:Bounds x="1500" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Flight Arrival -->
      <bpmndi:BPMNShape id="Task_FlightArrival_di" bpmnElement="Task_FlightArrival">
        <dc:Bounds x="1650" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Generate Invoice -->
      <bpmndi:BPMNShape id="Task_GenerateInvoice_di" bpmnElement="Task_GenerateInvoice">
        <dc:Bounds x="1800" y="270" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1952" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1928" y="335" width="85" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Edges -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="198" y="310" />
        <di:waypoint x="250" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="350" y="310" />
        <di:waypoint x="400" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="425" y="285" />
        <di:waypoint x="425" y="180" />
        <di:waypoint x="450" y="180" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="433" y="230" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="550" y="180" />
        <di:waypoint x="625" y="180" />
        <di:waypoint x="625" y="285" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="450" y="310" />
        <di:waypoint x="600" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="518" y="292" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="650" y="310" />
        <di:waypoint x="700" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="800" y="310" />
        <di:waypoint x="850" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <di:waypoint x="950" y="310" />
        <di:waypoint x="1000" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="900" y="368" />
        <di:waypoint x="900" y="432" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_10_di" bpmnElement="Flow_10">
        <di:waypoint x="1025" y="285" />
        <di:waypoint x="1025" y="200" />
        <di:waypoint x="1100" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_11_di" bpmnElement="Flow_11">
        <di:waypoint x="1025" y="335" />
        <di:waypoint x="1025" y="410" />
        <di:waypoint x="1100" y="410" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_12_di" bpmnElement="Flow_12">
        <di:waypoint x="1200" y="200" />
        <di:waypoint x="1275" y="200" />
        <di:waypoint x="1275" y="285" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_13_di" bpmnElement="Flow_13">
        <di:waypoint x="1200" y="410" />
        <di:waypoint x="1275" y="410" />
        <di:waypoint x="1275" y="335" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_14_di" bpmnElement="Flow_14">
        <di:waypoint x="1300" y="310" />
        <di:waypoint x="1350" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_15_di" bpmnElement="Flow_15">
        <di:waypoint x="1450" y="310" />
        <di:waypoint x="1500" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_16_di" bpmnElement="Flow_16">
        <di:waypoint x="1600" y="310" />
        <di:waypoint x="1650" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_17_di" bpmnElement="Flow_17">
        <di:waypoint x="1750" y="310" />
        <di:waypoint x="1800" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_18_di" bpmnElement="Flow_18">
        <di:waypoint x="1900" y="310" />
        <di:waypoint x="1952" y="310" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
