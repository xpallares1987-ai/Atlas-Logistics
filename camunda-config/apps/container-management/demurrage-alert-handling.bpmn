<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_Cont" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.25.0">
  <bpmn:process id="demurrage-alert-handling" name="Demurrage Alert Handling" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Discharge Complete">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:businessRuleTask id="Task_CalcFreeDays" name="Calculate Free Days">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="free-days-policy" resultVariable="freeDays" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:userTask id="Task_ReturnInstructions" name="Provide Return Instructions">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="camunda-forms:empty-return-instructions" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_1" name="Container Returned">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CalcFreeDays" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CalcFreeDays" targetRef="Task_ReturnInstructions" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ReturnInstructions" targetRef="EndEvent_1" />
  </bpmn:process>
</bpmn:definitions>
